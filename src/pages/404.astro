---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Página no encontrada | Michel Encarnación" lang="es">
  <main class="min-h-screen flex flex-col items-center justify-center bg-bg-primary-dark overflow-hidden relative px-4">

    <!-- Scanlines overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <!-- 404 heading -->
    <div class="text-404" aria-label="Error 404">
      <span class="digit d1">4</span>
      <span class="digit d2">0</span>
      <span class="digit d3">4</span>
    </div>

    <!-- Pixel art T-Rex -->
    <div class="dino-wrap" aria-hidden="true">
      <div class="dino"></div>
    </div>

    <!-- Message -->
    <div class="message">
      <p class="msg-title">El dino se comió esta página</p>
      <p class="msg-sub">Parece que esta URL no existe... o ya fue devorada.</p>
      <a href="/" class="btn-home">Volver al inicio</a>
    </div>

  </main>
</Layout>

<style>
  /* ─── Scanlines ───────────────────────────────────── */
  .scanlines {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
  }

  /* ─── 404 Text ─────────────────────────────────────── */
  .text-404 {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0.25rem;
    line-height: 1;
    margin-bottom: 2rem;
  }

  .digit {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(5rem, 20vw, 14rem);
    color: var(--color-accent);
    display: inline-block;
    text-shadow: 0 0 40px rgba(74, 222, 128, 0.4);
  }

  /* ─── Message ──────────────────────────────────────── */
  .message {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    margin-top: 2.5rem;
  }

  .msg-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    color: var(--color-text-primary-dark);
  }

  .msg-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 1rem;
    background-color: var(--color-accent);
    color: #000;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.2s, transform 0.2s;
  }

  .btn-home:hover {
    background-color: var(--color-accent-hover);
    transform: scale(1.05);
  }
</style>
